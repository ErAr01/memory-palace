# Telegram Bot
BOT_TOKEN=your_bot_token

# Telegram Userbot (для индексации)
API_ID=your_api_id
API_HASH=your_api_hash
PHONE_NUMBER=+995...

# PostgreSQL
# Для локальной разработки:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/memory_palace
# Для production (docker-compose.prod.yml) DATABASE_URL формируется автоматически

# PostgreSQL credentials (только для production)
POSTGRES_DB=memory_palace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
